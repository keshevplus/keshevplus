# Local development template. Copy to .env and fill values locally.
# Do not commit .env.

# Database
# Preferred local value. In Vercel, Neon may also provide POSTGRES_URL,
# KESHEVPLUS_POSTGRES_URL, POSTGRES_PRISMA_URL,
# KESHEVPLUS_POSTGRES_PRISMA_URL, POSTGRES_URL_NON_POOLING,
# KESHEVPLUS_POSTGRES_URL_NON_POOLING, or KESHEVPLUS_DATABASE_URL.
DATABASE_URL=

# Session
# Required in production. Use a long random string.
SESSION_SECRET=

# Email notifications and admin password reset
EMAIL_USER=
EMAIL_PASS=
CONTACT_RECIPIENT_EMAIL=

# AI chat
# OPENAI_API_KEY is preferred. Gemini is used as fallback.
OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=
GEMINI_API_KEY=
GOOGLE_API_KEY=
AI_INTEGRATIONS_GEMINI_API_KEY=
AI_INTEGRATIONS_GEMINI_BASE_URL=

# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
META_APP_SECRET=

# Optional scraper integration
FIRECRAWL_API_KEY=

# Owner seed script only
OWNER_EMAIL=dr@keshevplus.co.il
OWNER_PASSWORD=

# Runtime
NODE_ENV=development
