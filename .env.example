# Local development template. Copy to .env and fill values locally.
# Do not commit .env.

# Database
# The app checks DATABASE_URL first. Neon/Vercel aliases are optional fallbacks.
DATABASE_URL=
DATABASE_URL_UNPOOLED=
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
PGHOST=
PGHOST_UNPOOLED=
PGDATABASE=
PGUSER=
PGPASSWORD=
PGSSLMODE=require
PGCHANNELBINDING=require
POSTGRES_HOST=
POSTGRES_DATABASE=
POSTGRES_USER=
POSTGRES_PASSWORD=

# Session
# Use a long random value in production.
SESSION_SECRET=

# Owner seed script
OWNER_EMAIL=dr@keshevplus.co.il
OWNER_PASSWORD=

# Email notifications
# server/routes.ts currently reads EMAIL_USER and EMAIL_PASS.
EMAIL_USER=
EMAIL_PASS=
CONTACT_RECIPIENT_EMAIL=

# AI chat
OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=
GEMINI_API_KEY=
GOOGLE_API_KEY=
AI_INTEGRATIONS_GEMINI_API_KEY=
AI_INTEGRATIONS_GEMINI_BASE_URL=

# Optional scraper integration
FIRECRAWL_API_KEY=

# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
META_APP_SECRET=

# Runtime
NODE_ENV=development
