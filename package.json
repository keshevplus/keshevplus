{
  "name": "keshevplus-monorepo",
  "description": "KeshevPlus monorepo for the Vite + React + shadcn UI application.",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "NODE_ENV=development tsx server/index.ts",
    "build": "npm run build --prefix client && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outfile=dist/index.js && esbuild server/vercel-handler.ts --platform=node --packages=external --bundle --format=esm --outfile=api/index.js",
    "start": "NODE_ENV=production node dist/index.js",
    "db:push": "drizzle-kit push",
    "db:push:force": "drizzle-kit push --force",
    "typecheck": "npm run typecheck --prefix client",
    "lint": "npm run lint --prefix client",
    "test": "npm run test --prefix client"
  },
  "dependencies": {
    "@google/genai": "^1.40.0",
    "bcryptjs": "^2.4.3",
    "connect-pg-simple": "^10.0.0",
    "drizzle-orm": "^0.36.4",
    "drizzle-zod": "^0.5.1",
    "express": "^4.21.1",
    "express-session": "^1.18.1",
    "nodemailer": "^8.0.1",
    "openai": "^6.21.0",
    "p-limit": "^7.3.0",
    "p-retry": "^7.1.1",
    "pg": "^8.13.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/node": "^22.5.5",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.28.1",
    "esbuild": "^0.24.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3",
    "vite": "^5.4.15"
  }
}
